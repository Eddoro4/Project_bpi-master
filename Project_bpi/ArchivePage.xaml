<UserControl x:Class="Project_bpi.ArchivePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="110"/>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF225CAB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FilterRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FF004AA1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#FFBAD2DF" CornerRadius="25" Margin="30"/>

        <Popup x:Name="FilterPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=FilterButton}"
               Width="320"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="#FFF5F7FA"
                    CornerRadius="20"
                    BorderBrush="#D6E4FF"
                    BorderThickness="1"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Фильтр архива"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#FF004AA1"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Тип отчета"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <RadioButton x:Name="RadioAll"
                                     Content="Все"
                                     GroupName="ReportType"
                                     Style="{StaticResource FilterRadioButtonStyle}"
                                     IsChecked="True"/>
                        <RadioButton x:Name="RadioResearch"
                                     Content="Отчет"
                                     GroupName="ReportType"
                                     Style="{StaticResource FilterRadioButtonStyle}"/>
                        <RadioButton x:Name="RadioEducational"
                                     Content="Учебный"
                                     GroupName="ReportType"
                                     Style="{StaticResource FilterRadioButtonStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Поиск"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="FilterTextBox"
                             Margin="0,0,0,18"
                             Padding="10,8"
                             BorderBrush="#CCCCCC"
                             BorderThickness="1"
                             FontSize="12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Click="CancelFilter_Click"
                                Background="Transparent"
                                Foreground="#666666"
                                Padding="20,10"
                                Margin="0,0,10,0"
                                BorderThickness="0"
                                Cursor="Hand"
                                FontSize="12"
                                FontWeight="SemiBold"/>
                        <Button Content="Применить"
                                Click="ApplyFilterFixed_Click"
                                Style="{StaticResource FilterButtonStyle}"
                                Padding="20,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <ScrollViewer Margin="30" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Архив отчетов"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF004AA1"/>

                        <TextBlock x:Name="SummaryText"
                                   Foreground="#5F6B76"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button x:Name="FilterButton"
                            Grid.Column="1"
                            Width="32"
                            Height="32"
                            Margin="12,0,0,0"
                            Click="Filter_Click"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Cursor="Hand">
                        <Image Source="/Снимок экрана 2025-11-17 121115.png" Stretch="Fill"/>
                    </Button>
                </Grid>

                <TextBlock x:Name="EmptyStateText"
                           Text="Архив пока пуст."
                           Foreground="#5F6B76"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           Visibility="Collapsed"/>

                <ItemsControl x:Name="ArchiveItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    CornerRadius="10"
                                    Margin="0,0,0,10"
                                    Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF004AA1"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding ArchivedAtText}"
                                                   Margin="0,6,0,0"
                                                   Foreground="#5F6B76"
                                                   TextWrapping="Wrap"/>

                                        <WrapPanel Margin="0,12,0,0">
                                            <Border Background="#EEF4FF"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{Binding ReportType}"
                                                           Foreground="#355070"
                                                           FontWeight="SemiBold"/>
                                            </Border>

                                            <Border Background="#EEF4FF"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{Binding SectionsText}"
                                                           Foreground="#355070"
                                                           FontWeight="SemiBold"/>
                                            </Border>

                                            <Border Background="#EEF4FF"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{Binding TablesText}"
                                                           Foreground="#355070"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                        <Button Content="Скачать"
                                                Tag="{Binding}"
                                                Click="DownloadArchivedReportButton_Click"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#EEF4FF"
                                                Foreground="#FF004AA1"
                                                BorderBrush="#D6E4FF"
                                                Margin="0,0,0,8"/>

                                        <Button Content="Удалить"
                                                Tag="{Binding}"
                                                Click="DeleteArchivedReportButton_Click"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Background="#FFF2F2"
                                                Foreground="#C1121F"
                                                BorderBrush="#F6C9CF"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
