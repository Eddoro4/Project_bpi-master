<UserControl x:Class="Project_bpi.HistoryChangesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="White">

    <UserControl.Resources>
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF225CAB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF7A9BC8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF5A7BA8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#FFBAD2DF" CornerRadius="25" Margin="30"/>

        <Popup x:Name="FilterPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=FilterButton}"
               AllowsTransparency="True"
               PopupAnimation="Slide"
               StaysOpen="False">
            <Border Background="White"
                    CornerRadius="18"
                    BorderBrush="#D7E1E8"
                    BorderThickness="1"
                    Padding="18"
                    Width="320">
                <StackPanel>
                    <TextBlock Text="Фильтры истории"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#FF004AA1"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Тип действия"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#4A4A4A"
                               Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,14">
                        <CheckBox x:Name="CheckCreate"
                                  Content="Создание"
                                  IsChecked="True"
                                  Style="{StaticResource FilterCheckBoxStyle}"/>
                        <CheckBox x:Name="CheckEdit"
                                  Content="Редактирование"
                                  IsChecked="True"
                                  Style="{StaticResource FilterCheckBoxStyle}"/>
                        <CheckBox x:Name="CheckDelete"
                                  Content="Удаление"
                                  IsChecked="True"
                                  Style="{StaticResource FilterCheckBoxStyle}"/>
                    </WrapPanel>

                    <TextBlock Text="Период выбирается через календарь справа"
                               Foreground="#5F6B76"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сбросить"
                                Click="ResetFilter_Click"
                                Style="{StaticResource FilterButtonStyle}"
                                Background="Transparent"
                                Foreground="#666666"
                                Padding="16,10"
                                Margin="0,0,10,0"/>
                        <Button Content="Применить"
                                Click="ApplyFilter_Click"
                                Style="{StaticResource FilterButtonStyle}"
                                Padding="16,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <ScrollViewer Margin="30" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="История изменений"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FF004AA1"
                               VerticalAlignment="Center"/>

                    <Button x:Name="FilterButton"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Background="{x:Null}"
                            BorderBrush="{x:Null}"
                            Width="25"
                            Height="25"
                            Click="Filter_Click">
                        <Image Source="/Снимок экрана 2025-11-17 121115.png" Stretch="Fill"/>
                    </Button>
                </Grid>

                <TextBlock x:Name="SummaryText"
                           Foreground="#5F6B76"
                           Margin="0,0,0,14"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="EmptyStateText"
                           Text="История изменений пока пуста."
                           Foreground="#5F6B76"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"
                           Visibility="Collapsed"/>

                <ItemsControl x:Name="HistoryItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    CornerRadius="10"
                                    Margin="0,0,0,10"
                                    Padding="15">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding ChangedAtDisplay}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF004AA1"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Location}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="#FF004AA1"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Margin="12,0"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ActionDisplay}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding ActionBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap"/>
                                    </Grid>

                                    <TextBlock Text="{Binding Details}"
                                               Foreground="#5F6B76"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding DetailsVisibility}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
