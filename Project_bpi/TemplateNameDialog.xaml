<Window x:Class="Project_bpi.TemplateNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый шаблон"
        Width="420"
        MinHeight="220"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#f8f9fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTextBlock"
                   Text="Введите название шаблона"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#0167a4"
                   TextWrapping="Wrap"/>

        <TextBlock x:Name="LabelTextBlock"
                   Grid.Row="1"
                   Margin="0,12,0,8"
                   Text="Название"
                   Foreground="#495057"/>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#ced4da"
                BorderThickness="1"
                CornerRadius="8"
                Padding="2">
            <TextBox x:Name="TemplateNameTextBox"
                     MinHeight="38"
                     Padding="8,6"
                     Background="Transparent"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Отмена"
                    Width="92"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Добавить"
                    x:Name="ConfirmButton"
                    Width="92"
                    IsDefault="True"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
