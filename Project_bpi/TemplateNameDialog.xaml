<Window x:Class="Project_bpi.TemplateNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый шаблон"
        Height="190"
        Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#f8f9fa">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Введите название шаблона"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#0167a4"/>

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,8"
                   Text="Название"
                   Foreground="#495057"/>

        <TextBox x:Name="TemplateNameTextBox"
                 Grid.Row="2"
                 Height="34"
                 Padding="8,6"
                 VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Отмена"
                    Width="92"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Добавить"
                    Width="92"
                    IsDefault="True"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
